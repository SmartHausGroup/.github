# SMARTHAUS repo CI/CD conformance Make targets

# SMARTHAUS_REPO_CICD_CONFORMANCE_START
SHELL := /bin/bash
PY ?= python3
VENV_PY ?= $(PY)
CICD_PY ?= $(shell if [ -x "$(VENV_PY)" ]; then echo "$(VENV_PY)"; elif command -v python3 >/dev/null 2>&1; then echo python3; else echo python; fi)
.PHONY: repo-cicd-conformance ai-evidence-pack ai-pack-verify prepare-publication publication-ready push-safe ai-status ai-validate ai-validate-full

ai-status:
	@git status --short --branch

ai-validate: repo-cicd-conformance
	@echo "repo baseline validation complete"

ai-validate-full: ai-validate repo-cicd-conformance
	@echo "full repo CI/CD conformance validation complete"

repo-cicd-conformance:
	@$(CICD_PY) scripts/ci/verify_repo_cicd_conformance.py

ai-evidence-pack:
	@$(CICD_PY) scripts/ci/build_repo_cicd_evidence.py

ai-pack-verify: repo-cicd-conformance
	@$(CICD_PY) -m json.tool artifacts/scorecards/cicd_conformance.json >/dev/null
	@test -f artifacts/cicd/repo_cicd_evidence.json || $(CICD_PY) scripts/ci/build_repo_cicd_evidence.py

prepare-publication: ai-validate-full ai-evidence-pack ai-pack-verify
	@git write-tree > .git/ucp-prepared-tree
	@echo "Prepared tree: $$(cat .git/ucp-prepared-tree)"

publication-ready:
	@test -f .git/ucp-prepared-tree
	@test "$$(cat .git/ucp-prepared-tree)" = "$$(git write-tree)"
	@echo "Publication tree is prepared"

push-safe: publication-ready
	@git push

# SMARTHAUS_REPO_CICD_CONFORMANCE_END
