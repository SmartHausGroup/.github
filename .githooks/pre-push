#!/usr/bin/env bash
set -euo pipefail

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "${local_sha}" =~ ^0+$ ]]; then
    continue
  fi

  if [[ "${remote_sha}" =~ ^0+$ ]]; then
    range="${local_sha}"
  else
    range="${remote_sha}..${local_sha}"
  fi

  for commit in $(git rev-list "${range}"); do
    tree="$(git show -s --format=%T "${commit}")"
    trailer="$(git show -s --format=%B "${commit}" | awk -F': ' '/^UCP-Prepared-Tree:/ {print $2}' | tail -n 1)"
    if [[ -z "${trailer}" || "${trailer}" != "${tree}" ]]; then
      echo "pre-push blocked: ${commit} missing matching UCP-Prepared-Tree trailer." >&2
      exit 1
    fi
  done
done
