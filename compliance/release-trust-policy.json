{
  "schema_version": "smarthaus.release-trust-policy.v1",
  "require_slsa_provenance": true,
  "require_keyless_cosign_bundle": true,
  "require_digest_manifest": true,
  "require_protected_release_tags": true,
  "protected_tag_pattern": "refs/tags/v*",
  "source_archive": {
    "path": "source.tar.gz",
    "mtime": "UTC 1970-01-01",
    "owner": "0",
    "group": "0",
    "file_order": "git ls-files sorted bytewise"
  },
  "failure_mode": "fail_closed"
}
