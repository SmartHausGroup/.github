{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan-template-v1.0",
  "title": "Master Plan Schema",
  "description": "JSON Schema for validating execution plan JSON files. See agent_governance/PLAN_TEMPLATE.md for full documentation.",
  "type": "object",
  "required": [
    "plan_id",
    "parent_plan_id",
    "title",
    "version",
    "status",
    "owner",
    "date_created",
    "date_updated",
    "north_star_ref",
    "execution_plan_ref",
    "domain",
    "math_algorithm_scope",
    "north_star_alignment",
    "intent_capture",
    "objective",
    "current_state",
    "target_state",
    "scope",
    "requirements",
    "execution_sequence",
    "tasks",
    "gates",
    "artifacts",
    "environment",
    "implementation_approach",
    "risks",
    "rollback",
    "traceability",
    "governance_closure",
    "agent_constraints",
    "references"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "pattern": "^plan:[a-z0-9-]+$",
      "description": "Unique plan identifier in format plan:{kebab-name}"
    },
    "parent_plan_id": {
      "type": ["string", "null"],
      "description": "Parent plan ID or null if top-level"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable plan title"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Semver version (e.g. 1.0, 1.1)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "in-progress", "complete", "blocked", "cancelled", "failed"],
      "description": "Current plan status; see Lifecycle State Machine in PLAN_TEMPLATE.md"
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "description": "Team or individual owning this plan"
    },
    "date_created": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO date of plan creation"
    },
    "date_updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO date of last plan update"
    },
    "north_star_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Path to project North Star document (e.g. docs/governance/NORTH_STAR.md)"
    },
    "execution_plan_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Section or item in docs/governance/EXECUTION_PLAN.md"
    },
    "domain": {
      "type": "string",
      "enum": ["framework", "app", "infrastructure", "governance"],
      "description": "Work domain"
    },
    "math_algorithm_scope": {
      "type": "boolean",
      "description": "True if plan involves math/algorithm work requiring MA-in-MATHS"
    },
    "north_star_alignment": {
      "type": "object",
      "required": ["source", "principles", "anti_alignment"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Path to North Star document"
        },
        "principles": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Specific North Star principles this plan serves"
        },
        "anti_alignment": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "What this plan explicitly does NOT change"
        }
      }
    },
    "intent_capture": {
      "type": "object",
      "required": ["user_stated_requirements", "intent_doc_ref", "intent_verification"],
      "properties": {
        "user_stated_requirements": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "User's requirements in their words or unambiguous paraphrase"
        },
        "intent_doc_ref": {
          "type": "string",
          "description": "Path to intent doc or 'captured in this plan'"
        },
        "intent_verification": {
          "type": "string",
          "description": "Statement tracing plan Rx to user stated requirements"
        }
      }
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "description": "1-3 sentence statement of what this plan delivers"
    },
    "current_state": {
      "type": "string",
      "minLength": 1,
      "description": "What is broken or missing right now"
    },
    "target_state": {
      "type": "string",
      "minLength": 1,
      "description": "What done looks like with measurable outcomes"
    },
    "scope": {
      "type": "object",
      "required": ["in_scope", "out_of_scope", "file_allowlist", "file_denylist"],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "file_allowlist": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Exact paths or globs the agent MAY touch"
        },
        "file_denylist": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Exact paths or globs the agent MUST NOT touch"
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "ref", "description", "acceptance_criteria", "depends_on", "user_intent_trace"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R[0-9]+$",
            "description": "Requirement ID (R1, R2, etc.)"
          },
          "ref": {
            "type": "string",
            "pattern": "^plan:[a-z0-9-]+:R[0-9]+$",
            "description": "Full plan reference"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_criteria": {
            "type": "string",
            "minLength": 1,
            "description": "Measurable: boolean gate or numeric threshold"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of Rx IDs this depends on"
          },
          "user_intent_trace": {
            "type": "string",
            "minLength": 1,
            "description": "Which user stated requirement this satisfies"
          }
        }
      },
      "minItems": 1
    },
    "execution_sequence": {
      "type": "object",
      "required": ["ordering", "stop_on_first_failure"],
      "properties": {
        "ordering": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Task IDs in strict execution order"
        },
        "stop_on_first_failure": {
          "type": "boolean"
        },
        "maths_phase_mapping": {
          "type": ["object", "null"],
          "additionalProperties": {
            "type": ["string", "null"],
            "enum": ["M", "A", "T", "H", "S", null]
          },
          "description": "Task ID to MATHS phase mapping. Required if math_algorithm_scope is true."
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "ref", "name", "description", "requirement_refs", "depends_on", "deliverables", "exit_criteria", "validation_command"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Task ID (T1, T2, etc.)"
          },
          "ref": {
            "type": "string",
            "description": "Full plan reference: plan:{plan-id}:{task-id}"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "requirement_refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Which Rx IDs this task satisfies"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Task IDs that must complete first"
          },
          "maths_phase": {
            "type": ["string", "null"],
            "enum": ["M", "A", "T", "H", "S", null]
          },
          "deliverables": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Specific file paths or artifacts produced"
          },
          "exit_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Verifiable conditions (command output, file existence, assertion)"
          },
          "validation_command": {
            "type": "string",
            "minLength": 1,
            "description": "Exact executable command; for human-only steps use requires_human_approval and block_if_unset instead"
          },
          "implementation_notes": {
            "type": ["string", "null"],
            "description": "Code patterns, approaches, decisions"
          }
        }
      },
      "minItems": 1
    },
    "gates": {
      "type": "object",
      "required": ["checks", "decision", "no_go_triggers"],
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "description", "task_ref", "validation_command", "pass_criteria", "fail_action"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^CHECK:C[0-9]+$"
              },
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "task_ref": {
                "type": "string",
                "description": "Task ID this gate validates"
              },
              "validation_command": { "type": "string", "minLength": 1 },
              "pass_criteria": { "type": "string", "minLength": 1 },
              "fail_action": {
                "type": "string",
                "enum": ["block", "rollback", "escalate"]
              }
            }
          },
          "minItems": 1
        },
        "decision": {
          "type": "object",
          "required": ["go_rule", "no_go_rule"],
          "properties": {
            "go_rule": { "type": "string" },
            "no_go_rule": { "type": "string" }
          }
        },
        "no_go_triggers": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "determinism": {
      "type": ["object", "null"],
      "description": "Required if math_algorithm_scope is true. Null otherwise.",
      "properties": {
        "seed_locking": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "Library name to seed value mapping"
        },
        "device_policy": { "type": "string" },
        "float_precision": { "type": "string" },
        "replay_verification": {
          "type": "object",
          "properties": {
            "seeds": {
              "type": "array",
              "items": { "type": "integer" }
            },
            "comparison": { "type": "string" }
          }
        },
        "deterministic_algorithms": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "format", "producer", "validation"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "format": {
            "type": "string",
            "enum": ["JSON", "YAML", "pt", "ipynb", "py", "cpp", "hpp", "txt", "md", "other"]
          },
          "producer": {
            "type": "string",
            "description": "Task ID that generates this artifact"
          },
          "schema_ref": {
            "type": ["string", "null"],
            "description": "Link to schema or 'inline' or null"
          },
          "validation": {
            "type": "string",
            "description": "How to validate (no NaN/Inf, schema match, etc.)"
          }
        }
      },
      "minItems": 1
    },
    "environment": {
      "type": "object",
      "required": ["python_version", "venv"],
      "properties": {
        "python_version": { "type": "string" },
        "venv": {
          "type": "string",
          "description": "Path to project Python interpreter (e.g. .venv/bin/python)"
        },
        "additional_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "hardware": { "type": "string" },
        "external_data": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pre_notebook_check": { "type": ["string", "null"] }
      }
    },
    "implementation_approach": {
      "type": "object",
      "required": ["options_considered", "chosen", "rationale"],
      "properties": {
        "options_considered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description", "pros", "cons"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "pros": { "type": "array", "items": { "type": "string" } },
              "cons": { "type": "array", "items": { "type": "string" } }
            }
          },
          "minItems": 1
        },
        "chosen": { "type": "string" },
        "rationale": { "type": "string" },
        "rejected_rationale": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "adr_ref": { "type": ["string", "null"] }
      }
    },
    "risks": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["risk", "impact", "mitigation", "status"],
            "properties": {
              "risk": { "type": "string" },
              "impact": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "mitigation": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["open", "mitigated", "accepted", "materialized"]
              }
            }
          }
        },
        "hard_blockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "rollback": {
      "type": "object",
      "required": ["procedure", "files_to_revert", "artifacts_to_delete", "governance_updates_on_rollback"],
      "properties": {
        "procedure": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "files_to_revert": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifacts_to_delete": {
          "type": "array",
          "items": { "type": "string" }
        },
        "governance_updates_on_rollback": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "prompt_references": {
      "type": ["object", "null"],
      "properties": {
        "maths_template": { "type": ["string", "null"] },
        "prompt_doc": { "type": ["string", "null"] },
        "prompt_kickoff": { "type": ["string", "null"] },
        "per_task_prompts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "traceability": {
      "type": "object",
      "required": ["files_created", "index_updates"],
      "properties": {
        "files_created": {
          "type": "object",
          "properties": {
            "notebooks": { "type": "array", "items": { "type": "string" } },
            "invariants": { "type": "array", "items": { "type": "string" } },
            "lemmas": { "type": "array", "items": { "type": "string" } },
            "code_files": { "type": "array", "items": { "type": "string" } },
            "config_artifacts": { "type": "array", "items": { "type": "string" } }
          }
        },
        "index_updates": {
          "type": "object",
          "properties": {
            "traceability_index": { "type": ["string", "null"] },
            "invariant_index": { "type": ["string", "null"] },
            "math_readme": { "type": ["string", "null"] },
            "lemmas_appendix": { "type": ["string", "null"] }
          }
        }
      }
    },
    "governance_closure": {
      "type": "object",
      "required": ["action_log", "execution_plan"],
      "properties": {
        "action_log": {
          "type": "string",
          "description": "Path to action log (e.g. docs/governance/ACTION_LOG)"
        },
        "execution_plan": {
          "type": "string",
          "description": "Path to execution plan (e.g. docs/governance/EXECUTION_PLAN.md)"
        },
        "project_status": {
          "type": ["string", "null"]
        },
        "invariant_promotions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lemma_promotions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "execution_outcome": {
      "type": "object",
      "description": "Filled during/after execution. All fields null in draft plans.",
      "properties": {
        "task_checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "task_id": { "type": "string" },
              "complete": { "type": "boolean" },
              "evidence": { "type": ["string", "null"] }
            }
          }
        },
        "gate_checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "gate_id": { "type": "string" },
              "result": {
                "type": ["string", "null"],
                "enum": ["pass", "fail", null]
              }
            }
          }
        },
        "final_decision": {
          "type": ["string", "null"],
          "enum": ["GO", "NO-GO", null]
        },
        "approved_by": { "type": ["string", "null"] },
        "completion_timestamp": { "type": ["string", "null"] }
      }
    },
    "when_blocked": {
      "type": "object",
      "required": ["format", "escalation"],
      "properties": {
        "format": {
          "type": "string",
          "description": "Exact blocked output format"
        },
        "escalation": {
          "type": "object",
          "required": ["primary"],
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": ["string", "null"] }
          }
        }
      }
    },
    "agent_constraints": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Constraints that apply to any agent executing this plan"
    },
    "references": {
      "type": "object",
      "required": ["north_star", "execution_plan", "applicable_rules"],
      "properties": {
        "north_star": { "type": "string" },
        "execution_plan": { "type": "string" },
        "applicable_rules": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "related_plans": {
          "type": "array",
          "items": { "type": "string" }
        },
        "related_docs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maths_prompt_template": { "type": ["string", "null"] }
      }
    }
  }
}
